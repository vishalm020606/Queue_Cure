# Backend API URL (Optional, defaults to http://localhost:3000 if blank)
VITE_BACKEND_URL=http://localhost:3000

# Firebase Web Client Configuration (For real Push Notifications. Left as mock by default)
VITE_FIREBASE_API_KEY=mock-api-key
VITE_FIREBASE_AUTH_DOMAIN=mock-app.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=mock-project
VITE_FIREBASE_STORAGE_BUCKET=mock-app.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=1234567890
VITE_FIREBASE_APP_ID=1:1234567890:web:abcdef123456

# Firebase Cloud Messaging VAPID Web Push Key (Optional)
VITE_FIREBASE_VAPID_KEY=your_firebase_vapid_key_here
